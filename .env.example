# Database
DATABASE_URL="file:./prisma/dev.db"

# Server
PORT=3001

# Geo: optional API key for IP geolocation (e.g. ip-api.com pro, MaxMind, ipinfo.io)
GEO_API_KEY=

# KYC doc verification provider webhook secret (e.g. Sumsub, Jumio, Onfido)
KYC_WEBHOOK_SECRET=

# Sanctions provider API (e.g. ComplyAdvantage, Chainalysis) – mock used if not set
SANCTIONS_API_KEY=
SANCTIONS_API_URL=

# Data retention (days) – documents and audit logs older than this can be purged/anonymized
RETENTION_DAYS_DOCUMENTS=2555
RETENTION_DAYS_AUDIT=2555
RETENTION_DAYS_PII=2555
